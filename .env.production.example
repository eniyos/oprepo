# Production secrets — copy to .env.production on the VM, never commit.
# All values are examples; replace with real credentials.

# Database
DATABASE_URL=postgresql://oprepo:oprepo@localhost:5432/oprepo

# Redis
REDIS_URL=redis://localhost:6379

# GitHub API token (required for profile fetching and trending updates)
GITHUB_TOKEN=ghp_your_token_here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=repositories

# ML Service
ML_SERVICE_URL=http://localhost:8000

# CORS
CORS_ORIGIN=https://oprepo.dev

# Backblaze B2 (optional — for database backups)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=oprepo-backups
